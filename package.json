{
  "name": "opencode-pet",
  "version": "1.0.2",
  "description": "Bring Codex pets to OpenCode — animated terminal companions that appear while models think",
  "type": "module",
  "types": "./src/plugin/index.tsx",
  "main": "./dist/plugin/index.js",
  "bin": {
    "opencode-pet": "dist/cli/index.js"
  },
  "exports": {
    "./tui": "./dist/plugin/index.js"
  },
  "files": [
    "src/plugin",
    "src/converter",
    "src/types.ts",
    "dist/cli",
    "dist/converter",
    "dist/plugin",
    "dist/types.js",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node ./scripts/build-plugin.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.plugin.json",
    "generate-default-pet": "node ./scripts/generate-default-pet.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "codex",
    "pet",
    "companion",
    "terminal",
    "animation",
    "thinking",
    "ai",
    "open source"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aramirez087/opencode-pet.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "^0.2.2",
    "sharp": "^0.33.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@opencode-ai/plugin": "1.14.20",
    "@opentui/solid": "^0.2.2",
    "@types/node": "^22.0.0",
    "babel-preset-solid": "^1.9.0",
    "esbuild": "^0.25.12",
    "solid-js": "^1.9.0",
    "typescript": "^5.8.0"
  }
}
